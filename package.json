{
  "name": "cloudflare-demo",
  "description": "Cloudflare Workers + SvelteKit monorepo",
  "version": "1.0.1",
  "private": true,
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter @cloudflare-demo/backend dev",
    "dev:frontend": "pnpm --filter @cloudflare-demo/frontend dev",
    "build": "pnpm -r build",
    "deploy:frontend": "pnpm --filter @cloudflare-demo/frontend run deploy",
    "deploy:backend": "pnpm --filter @cloudflare-demo/backend run deploy",
    "deploy:all": "pnpm run deploy:backend && pnpm run deploy:frontend",
    "preview": "pnpm --filter @cloudflare-demo/frontend preview",
    "check": "pnpm --filter @cloudflare-demo/frontend check",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "biome check .",
    "audit": "pnpm audit",
    "format": "biome format --write .",
    "quality": "pnpm lint && pnpm test:coverage && pnpm audit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0"
  }
}
